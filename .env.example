# ElevenLabs DJ voice (optional).
# The app runs fully without these — the "Play DJ voice" buttons just stay
# disabled with an "Add ElevenLabs keys to enable DJ voice" message.
#
# Create an API key scoped to: Text to Speech = Access, everything else = No Access.
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
