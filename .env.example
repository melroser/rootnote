# ElevenLabs DJ voice (optional).
# The app runs fully without these — the "Play DJ voice" buttons just stay
# disabled with an "Add ElevenLabs keys to enable DJ voice" message.
#
# Create an API key scoped to: Text to Speech = Access, everything else = No Access.
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# OpenAI (optional) — enables real "generate an episode from any prompt".
# Without it, the app falls back to the offline generation engine + presets,
# so nothing breaks; add a key to unlock full any-input generation.
OPENAI_API_KEY=your_key_here

# YouTube Data API v3 key (optional) — enables on-the-fly REAL playlists/embeds
# for generated episodes: resolves each AI/offline track to a real video ID so
# it plays inline and gets an anonymous watch_videos queue. Without it,
# generated tracks fall back to "Open search on YouTube" (curated episodes are
# unaffected either way). Note: each search costs 100 quota units.
YOUTUBE_API_KEY=your_key_here
